<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="RIO Waardenlijsten" id="id-76f1784e026a46c3bc8c3442bcbc1454" version="5.0.0">
