      <property key="Naam (EN)"/>
      <property key="Lange naam (EN)"/>
      <property key="Wettelijk niveau (OCW) code &amp; naam"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Onderwijsrichting" id="id-b75cf602dc2f40828c5da44ca3a3c60b">
      <documentation>Onderwijs die lerende opleidt voor een specifiek beheersingsniveau/uitstroomprofiel.&#xD;
Synoniem: Onderwijsniveau(?)&#xD;
&#xD;
Bronnen: &#xD;
Waardenlijsten RIO-po [zie https://www.edustandaard.nl/standaard_afspraken/waardenlijsten-rio-po ] en Waardenlijsten RIO-vo [zie https://www.edustandaard.nl/standaard_afspraken/waardenlijsten-rio-vo ], met name: &#xD;
- Concept - Waardenlijst niveaus, schooljaar 2025-2026 v0.91  [zie https://www.edustandaard.nl/app/uploads/2025/07/Waardenlijst-niveaus-schooljaar-2025-2026-v0.91.xlsx ].&#xD;
</documentation>
      <property key="Naam"/>
      <property key="Werkingsgebied (ROSA)"/>
      <property key="Sector (OCW)"/>
      <property key="Maximaal aantal leerjaren"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Opleidingskenmerk" id="id-f2732de17dbf43b78a73981537534ee0">
      <documentation>Opleidingskenmerk is een manier waarop een opleiding gegeven kan worden. &#xD;
Bijvoorbeeld voor bo: Montessori, IGBO, tweetalig primair onderwijs. &#xD;
Bijvoorbeeld voor so en vso: ondersteuning bij visuele beperkingen, ondersteuning bij doofheid.&#xD;
Bijvoorbeeld voor vo: Montessori, TTO, Technasium.&#xD;
&#xD;
Bronnen: &#xD;
Waardenlijsten RIO-po [zie https://www.edustandaard.nl/standaard_afspraken/waardenlijsten-rio-po ], met name: &#xD;
- Waardenlijst Opleidingskenmerken bo, so, vso, schooljaar 2025-2026 v1.0 [zie https://www.edustandaard.nl/app/uploads/2025/07/Waardenlijst-Opleidingskenmerken-bo-so-vso-schooljaar-2025-2026-v1.0.xlsx ] en &#xD;
Waardenlijsten RIO-vo [zie https://www.edustandaard.nl/standaard_afspraken/waardenlijsten-rio-vo ], met name: &#xD;
- Waardenlijst Waardenlijst Opleidingskenmerken vo, schooljaar 2025-2026 v1.0 [zie https://www.edustandaard.nl/app/uploads/2025/07/Waardenlijst-Opleidingskenmerken-vo-schooljaar-2025-2026-v1.0.xlsx ].&#xD;
</documentation>
      <property key="Aanduiding"/>
